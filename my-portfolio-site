<style>
  :root{
    --navy:#0b1220;
    --navy-2:#0f1b33;
    --accent:#22d3ee;
    --accent-2:#6366f1;
    --grad: linear-gradient(120deg,#22d3ee 0%,#6366f1 100%);
    --text:#e6ebf5;
    --muted:#9aa7c2;
    --card:#121b30;
    --card-border:#22304f;
    --light:#f7f9fc;
    --light-muted:#5c6a86;
    --radius:16px;
    --maxw:1180px;
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  html{scroll-behavior:smooth;}
  body{
    font-family:'Segoe UI',-apple-system,BlinkMacSystemFont,Roboto,Helvetica,Arial,sans-serif;
    background:var(--light);
    color:#1a2236;
    line-height:1.6;
    overflow-x:hidden;
  }
  a{text-decoration:none;color:inherit;}
  ul{list-style:none;}
  img{max-width:100%;display:block;}
  .wrap{max-width:var(--maxw);margin:0 auto;padding:0 24px;}
  section{padding:100px 0;}
  h1,h2,h3,h4{line-height:1.2;font-weight:800;}
  .eyebrow{
    display:inline-block;
    font-size:13px;
    font-weight:700;
    letter-spacing:1.5px;
    text-transform:uppercase;
    color:var(--accent-2);
    background:rgba(99,102,241,0.08);
    padding:6px 14px;
    border-radius:999px;
    margin-bottom:18px;
  }
  .section-head{max-width:680px;margin:0 auto 56px;text-align:center;}
  .section-head h2{font-size:clamp(28px,4vw,40px);margin-bottom:14px;color:#0b1220;}
  .section-head p{color:var(--light-muted);font-size:17px;}

  /* NAV */
  header{
    position:fixed;top:0;left:0;right:0;z-index:1000;
    background:rgba(11,18,32,0.85);
    backdrop-filter:blur(10px);
    border-bottom:1px solid rgba(255,255,255,0.06);
  }
  nav.wrap{
    display:flex;align-items:center;justify-content:space-between;
    height:76px;
  }
  .logo{font-weight:800;font-size:19px;color:#fff;letter-spacing:0.3px;}
  .logo span{color:var(--accent);}
  .nav-links{display:flex;gap:34px;align-items:center;}
  .nav-links a{color:var(--muted);font-size:15px;font-weight:600;transition:color .2s;}
  .nav-links a:hover{color:#fff;}
  .nav-cta{
    background:var(--grad);color:#08111f !important;padding:10px 22px;border-radius:999px;
    font-weight:700;font-size:14px;
  }
  .burger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;}
  .burger span{width:26px;height:2px;background:#fff;border-radius:2px;}

  /* HERO */
  .hero{
    background:radial-gradient(circle at 20% 20%, #17223d 0%, var(--navy) 55%, #060a13 100%);
    color:#fff;padding:190px 0 130px;position:relative;overflow:hidden;
  }
  .hero::before{
    content:"";position:absolute;width:600px;height:600px;border-radius:50%;
    background:radial-gradient(circle,rgba(34,211,238,0.18),transparent 70%);
    top:-150px;right:-150px;
  }
  .hero::after{
    content:"";position:absolute;width:500px;height:500px;border-radius:50%;
    background:radial-gradient(circle,rgba(99,102,241,0.16),transparent 70%);
    bottom:-200px;left:-100px;
  }
  .hero-grid{display:grid;grid-template-columns:1.15fr 0.85fr;gap:60px;align-items:center;position:relative;z-index:2;}
  .hero h1{font-size:clamp(34px,5vw,54px);margin-bottom:22px;}
  .hero h1 .grad-text{
    background:var(--grad);-webkit-background-clip:text;background-clip:text;color:transparent;
  }
  .hero p.lead{color:var(--muted);font-size:18px;max-width:560px;margin-bottom:34px;}
  .btn-row{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:40px;}
  .btn{
    display:inline-flex;align-items:center;gap:8px;padding:14px 26px;border-radius:10px;
    font-weight:700;font-size:15px;transition:transform .2s, box-shadow .2s;border:none;cursor:pointer;
  }
  .btn-primary{background:var(--grad);color:#07111f;box-shadow:0 10px 30px rgba(34,211,238,0.25);}
  .btn-primary:hover{transform:translateY(-2px);box-shadow:0 14px 34px rgba(34,211,238,0.35);}
  .btn-outline{border:1.5px solid rgba(255,255,255,0.25);color:#fff;}
  .btn-outline:hover{background:rgba(255,255,255,0.08);}
  .hero-stats{display:flex;gap:34px;flex-wrap:wrap;}
  .hero-stats div{min-width:110px;}
  .hero-stats .num{font-size:26px;font-weight:800;color:#fff;}
  .hero-stats .lbl{font-size:13px;color:var(--muted);}
  .hero-card{
    background:var(--card);border:1px solid var(--card-border);border-radius:var(--radius);
    padding:30px;box-shadow:0 30px 60px rgba(0,0,0,0.35);
  }
  .hero-card h4{color:#fff;font-size:15px;margin-bottom:18px;display:flex;align-items:center;gap:8px;}
  .hero-card .dot{width:8px;height:8px;border-radius:50%;background:var(--accent);}
  .service-tag{
    display:flex;align-items:center;justify-content:space-between;
    padding:12px 14px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.05);
    border-radius:10px;margin-bottom:10px;color:var(--text);font-size:14px;font-weight:600;
  }
  .service-tag small{color:var(--muted);font-weight:500;}

  /* LOGOS / TRUST STRIP */
  .trust{background:#fff;padding:34px 0;border-bottom:1px solid #eef1f6;}
  .trust .wrap{display:flex;flex-wrap:wrap;gap:28px;justify-content:center;align-items:center;color:#8a94ab;font-weight:700;font-size:14px;letter-spacing:.5px;text-transform:uppercase;}
  .trust span{opacity:.8;}

  /* SERVICES */
  .services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:26px;}
  .service-card{
    background:#fff;border:1px solid #eef1f6;border-radius:var(--radius);padding:32px 28px;
    transition:transform .25s, box-shadow .25s;position:relative;
  }
  .service-card:hover{transform:translateY(-6px);box-shadow:0 20px 40px rgba(15,27,51,0.09);}
  .service-icon{
    width:52px;height:52px;border-radius:14px;background:var(--grad);
    display:flex;align-items:center;justify-content:center;font-size:24px;margin-bottom:20px;
  }
  .service-card h3{font-size:19px;margin-bottom:10px;color:#0b1220;}
  .service-card p{color:var(--light-muted);font-size:14.5px;margin-bottom:18px;}
  .service-card a.link{font-weight:700;font-size:14px;color:var(--accent-2);display:inline-flex;align-items:center;gap:6px;}
  .service-card a.link:hover{text-decoration:underline;}

  /* WHY / VALUE PROPS */
  .why{background:var(--navy);color:#fff;}
  .why .section-head h2{color:#fff;}
  .why .section-head p{color:var(--muted);}
  .why-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;}
  .why-card{
    background:var(--card);border:1px solid var(--card-border);border-radius:var(--radius);
    padding:26px 22px;text-align:center;
  }
  .why-card .n{font-size:30px;margin-bottom:12px;}
  .why-card h4{font-size:15.5px;color:#fff;margin-bottom:8px;}
  .why-card p{font-size:13.5px;color:var(--muted);}

  /* PROJECTS */
  .projects-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:26px;}
  .project-card{
    background:#fff;border:1px solid #eef1f6;border-radius:var(--radius);padding:30px;
    transition:box-shadow .25s, transform .25s;
  }
  .project-card:hover{transform:translateY(-4px);box-shadow:0 18px 40px rgba(15,27,51,0.08);}
  .project-card .tagrow{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px;}
  .project-card .tagrow span{
    background:rgba(99,102,241,0.08);color:var(--accent-2);font-size:12px;font-weight:700;
    padding:5px 10px;border-radius:999px;
  }
  .project-card h3{font-size:18px;margin-bottom:10px;color:#0b1220;}
  .project-card p{color:var(--light-muted);font-size:14.5px;margin-bottom:16px;}
  .project-card .stack{font-size:12.5px;color:#8a94ab;border-top:1px solid #eef1f6;padding-top:14px;}

  /* SKILLS */
  .skills-wrap{display:flex;flex-wrap:wrap;gap:12px;justify-content:center;max-width:900px;margin:0 auto;}
  .chip{
    background:#fff;border:1px solid #e4e9f2;padding:10px 18px;border-radius:999px;
    font-size:14px;font-weight:700;color:#2a3653;
  }
  .chip.hi{background:var(--grad);color:#08111f;border:none;}

  /* EXPERIENCE TIMELINE */
  .timeline{max-width:760px;margin:0 auto;position:relative;padding-left:28px;border-left:2px solid #e4e9f2;}
  .tl-item{position:relative;margin-bottom:38px;}
  .tl-item:last-child{margin-bottom:0;}
  .tl-item::before{
    content:"";position:absolute;left:-35px;top:4px;width:14px;height:14px;border-radius:50%;
    background:var(--grad);border:3px solid #fff;box-shadow:0 0 0 2px #e4e9f2;
  }
  .tl-item .role{font-weight:800;font-size:17px;color:#0b1220;}
  .tl-item .meta{font-size:13.5px;color:#8a94ab;margin:4px 0 10px;font-weight:600;}
  .tl-item p{font-size:14.5px;color:var(--light-muted);}

  /* CONTACT / CTA */
  .cta{
    background:var(--navy-2);color:#fff;border-radius:28px;padding:70px 50px;text-align:center;
    position:relative;overflow:hidden;
  }
  .cta::before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 80% 20%, rgba(34,211,238,0.18), transparent 60%);}
  .cta h2{font-size:clamp(26px,4vw,38px);margin-bottom:16px;position:relative;}
  .cta p{color:var(--muted);max-width:560px;margin:0 auto 32px;position:relative;font-size:16px;}
  .contact-buttons{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;position:relative;}
  .contact-buttons .btn{font-size:15px;}
  .btn-whatsapp{background:#25D366;color:#062b13;}
  .btn-linkedin{background:#fff;color:#0b1220;}

  footer{background:var(--navy);color:var(--muted);padding:40px 0;text-align:center;font-size:14px;}
  footer a{color:#fff;font-weight:600;}

  .reveal{opacity:0;transform:translateY(24px);transition:opacity .6s ease, transform .6s ease;}
  .reveal.in{opacity:1;transform:translateY(0);}

  @media(max-width:980px){
    .services-grid{grid-template-columns:repeat(2,1fr);}
    .why-grid{grid-template-columns:repeat(2,1fr);}
    .projects-grid{grid-template-columns:1fr;}
    .hero-grid{grid-template-columns:1fr;}
    .hero{padding:150px 0 90px;}
  }
  @media(max-width:680px){
    section{padding:70px 0;}
    .nav-links{
      position:fixed;top:76px;left:0;right:0;background:var(--navy);
      flex-direction:column;padding:24px;gap:20px;
      transform:translateY(-130%);transition:transform .3s ease;border-bottom:1px solid rgba(255,255,255,.08);
    }
    .nav-links.open{transform:translateY(0);}
    .burger{display:flex;}
    .services-grid{grid-template-columns:1fr;}
    .why-grid{grid-template-columns:1fr;}
    .cta{padding:50px 24px;}
  }
</style>
</head>
